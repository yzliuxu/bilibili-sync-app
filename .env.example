# ========================================
# Bilibili Sync App - 环境配置文件
# ========================================
# 注意: 本文件包含敏感信息，不应该提交到版本控制系统
#      请复制此文件为 .env 并修改相应值

# ========== 应用程序配置 ==========
# 运行环境：development / production
ENVIRONMENT=production

# 是否启用调试模式（生产环境必须设为 false）
DEBUG=false

# 应用监听地址
APP_HOST=0.0.0.0
APP_PORT=8000

# ========== API 密钥配置 ==========
# ⚠️ 重要：请生成一个强密钥
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_API_KEY=your-very-long-random-secure-key-change-me-now

# ========== 数据库配置 ==========
# SQLite 配置（开发/小规模部署）
DATABASE_URL=sqlite:///./data/app.db

# PostgreSQL 配置（生产环境推荐）
# DATABASE_URL=postgresql://username:password@localhost:5432/bilibili_sync

# ========== CORS 配置 ==========
# 前端应用地址
FRONTEND_URL=http://localhost:5173

# 允许的来源列表（逗号分隔）
# 生产环境示例: https://example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# ========== 文件上传限制 ==========
# 限制单个文件上传大小（字节）：5GB = 5368709120
MAX_UPLOAD_SIZE=5368709120

# 临时文件存储路径
TEMP_DIR=./data/temp

# ========== 日志配置 ==========
# 日志级别: debug / info / warning / error
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=./logs/app.log

# ========== rclone 配置 ==========
# rclone 可执行文件路径
# 仅从该配置文件读取，不依赖运行环境的系统环境变量
# 示例（Linux）:
RCLONE_EXECUTABLE_PATH=/usr/bin/rclone
# 示例（自定义位置）:
# RCLONE_EXECUTABLE_PATH=/opt/rclone/rclone
# 示例（Windows）:
# RCLONE_EXECUTABLE_PATH=C:\Program Files\rclone\rclone.exe

# rclone 配置文件路径
RCLONE_CONFIG_PATH=/home/user/.config/rclone/rclone.conf

# 默认上传远程名称
RCLONE_REMOTE=115

# ========== 任务队列配置 ==========
# 最大并发任务数
MAX_CONCURRENT_TASKS=3

# 任务超时时间（秒）
TASK_TIMEOUT=3600

# ========== 第三方服务 ==========
# Redis 配置（可选，用于缓存）
# REDIS_URL=redis://localhost:6379

# ========== 发送邮件配置（可选）==========
# SMTP 服务器
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=app-password

# ========== 监控告警 ==========
# 是否启用监控
ENABLE_MONITORING=true

# Sentry DSN（错误追踪）
# SENTRY_DSN=https://xxxxxxxx@sentry.io/xxxxxxxx

# ========== 安全配置 ==========
# HTTPS 重定向
HTTPS_REDIRECT=false

# CORS 允许凭证
ALLOW_CREDENTIALS=true

# ========== 开发配置 ==========
# 跨源资源共享允许所有源（仅开发环境）
CORS_ALLOW_ALL=false

# SQL Alchemy 回显（显示所有 SQL 语句）
SQLALCHEMY_ECHO=false

# ========== 其他配置 ==========
# 应用名称
APP_NAME=Bilibili Sync App

# 版本号
APP_VERSION=1.0.0

# 时区
TZ=Asia/Shanghai
