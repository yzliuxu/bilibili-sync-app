# ========================================
# Bilibili Sync App - Tailscale 内网运行配置
# ========================================

# ========== 核心网络配置 ==========
# 填入你的 Tailscale 虚拟局域网 IP（通过 tailscale ip 命令查看）
# 如果留空或填 0.0.0.0，则会暴露在公网！
LISTEN_HOST=100.x.x.x
LISTEN_PORT=8000

# ========== 鉴权秘钥 ==========
# ⚠️ 重要：必须修改为复杂的任意字符串，防止内网横向越权攻击
SECRET_API_KEY=your-very-long-random-secure-key

# ========== Rclone 传输引擎 ==========
# Rclone 在 Linux 上的绝对路径
RCLONE_EXECUTABLE_PATH=/usr/bin/rclone
# 115 远端名称及挂载目录
RCLONE_REMOTE=115:/yt_downloads

# ========== 系统行为 ==========
# 运行环境
ENVIRONMENT=production
# 启用调试日志
DEBUG=false