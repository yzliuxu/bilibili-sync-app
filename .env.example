LISTEN_HOST=100.x.x.x
LISTEN_PORT=8000

# ========== 鉴权秘钥 ==========
# ⚠️ 重要：必须修改为复杂的任意字符串，防止内网横向越权攻击
SECRET_API_KEY=your-very-long-random-secure-key

# ========== Rclone 传输引擎 ==========
# Rclone 在 Linux 上的绝对路径
RCLONE_EXECUTABLE_PATH=/usr/bin/rclone
# 115 远端名称及挂载目录
RCLONE_REMOTE=115:/yt_downloads

# ========== 系统行为 ==========
# 运行环境
ENVIRONMENT=production
# 启用调试日志
DEBUG=false